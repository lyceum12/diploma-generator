<!DOCTYPE html>
<html>
<head>
    <title>Проверка диплома</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="verify-container">
    <h2>Проверка диплома</h2>
    <form method="POST" action="/verify">
        <input type="text" name="code" placeholder="Введите код подтверждения" value="<%= code %>" required>
        <button type="submit">Проверить</button>
    </form>
    <% if (diploma) { %>
        <div class="result">
            <h3>Результат проверки</h3>
            <p><strong>ФИО:</strong> <%= diploma.full_name %></p>
            <p><strong>Класс:</strong> <%= diploma.grade %></p>
            <p><strong>Учебное заведение:</strong> <%= diploma.school %></p>
            <p><strong>Олимпиада:</strong> <%= diploma.olympiad_name %></p>
            <p><strong>Профиль:</strong> <%= diploma.profile %></p>
            <p><strong>Уровень:</strong> <%= diploma.level %></p>
            <p><strong>Степень диплома:</strong> <%= diploma.degree %></p>
            <p><strong>Код подтверждения:</strong> <%= diploma.unique_code %></p>
            <p><strong>Дата выдачи:</strong> <%= new Date(diploma.created_at).toLocaleDateString() %></p>
            <div class="success">✅ Диплом действителен</div>
        </div>
    <% } else if (code) { %>
        <div class="error">❌ Диплом с таким кодом не найден</div>
    <% } %>
</div>
</body>
</html>
