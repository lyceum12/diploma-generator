<!DOCTYPE html>
<html>
<head>
    <title>Админ-панель</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="dashboard">
    <h1>Управление дипломами</h1>
    <div class="top-bar">
        <span>Вы вошли как <%= admin.username %></span>
        <a href="/admin/change-password">Сменить пароль</a> |
        <a href="/admin/logout">Выйти</a>
    </div>
    <hr>
    <h2><%= editing ? 'Редактировать диплом' : 'Создать новый диплом' %></h2>
    <form method="POST" action="<%= editing ? '/admin/edit/'+editing.id : '/admin/create' %>">
        <input type="text" name="full_name" placeholder="ФИО" value="<%= editing ? editing.full_name : '' %>" required>
        <input type="text" name="grade" placeholder="Класс" value="<%= editing ? editing.grade : '' %>" required>
        <input type="text" name="school" placeholder="Учебное заведение" value="<%= editing ? editing.school : '' %>" required>
        <input type="text" name="olympiad_name" placeholder="Название олимпиады" value="<%= editing ? editing.olympiad_name : 'Отраслевая олимпиада школьников «Газпром»' %>" required>
        <input type="text" name="profile" placeholder="Профиль" value="<%= editing ? editing.profile : 'математика' %>" required>
        <input type="text" name="level" placeholder="Уровень" value="<%= editing ? editing.level : '3' %>" required>
        <input type="text" name="number_in_list" placeholder="Номер в Перечне" value="<%= editing ? editing.number_in_list : '1' %>" required>
        <select name="degree" required>
            <option value="Победитель" <%= editing && editing.degree=='Победитель' ? 'selected' : '' %>>Победитель</option>
            <option value="Призёр" <%= editing && editing.degree=='Призёр' ? 'selected' : '' %>>Призёр</option>
            <option value="Диплом I степени" <%= editing && editing.degree=='Диплом I степени' ? 'selected' : '' %>>Диплом I степени</option>
            <option value="Диплом II степени" <%= editing && editing.degree=='Диплом II степени' ? 'selected' : '' %>>Диплом II степени</option>
            <option value="Диплом III степени" <%= editing && editing.degree=='Диплом III степени' ? 'selected' : '' %>>Диплом III степени</option>
        </select>
        <button type="submit"><%= editing ? 'Сохранить' : 'Создать диплом' %></button>
        <% if (editing) { %><a href="/admin/dashboard" class="cancel">Отмена</a><% } %>
    </form>
    <hr>
    <h2>Список дипломов</h2>
    <table border="1" cellpadding="8">
        <tr><th>ID</th><th>ФИО</th><th>Класс</th><th>Олимпиада</th><th>Код</th><th>PDF</th><th>Действия</th></tr>
        <% diplomas.forEach(d => { %>
        <tr>
            <td><%= d.id %></td>
            <td><%= d.full_name %></td>
            <td><%= d.grade %></td>
            <td><%= d.olympiad_name %></td>
            <td><%= d.unique_code %></td>
            <td><a href="/diploma/<%= d.id %>/pdf" target="_blank">Скачать PDF</a></td>
            <td>
                <a href="/admin/edit/<%= d.id %>">Редактировать</a>
                <form method="POST" action="/admin/delete/<%= d.id %>" style="display:inline;" onsubmit="return confirm('Удалить?')">
                    <button type="submit">Удалить</button>
                </form>
            </td>
        </tr>
        <% }) %>
    </table>
    <hr>
    <h3>Экспорт / Импорт базы данных</h3>
    <a href="/admin/export-db" class="button">Скачать database.sqlite</a>
    <form method="POST" action="/admin/import-db" enctype="multipart/form-data" style="margin-top:10px">
        <input type="file" name="dbFile" accept=".sqlite" required>
        <button type="submit">Заменить базу данных</button>
        <p style="color:red">Внимание: импорт полностью заменит текущую базу!</p>
    </form>
</div>
</body>
</html>
